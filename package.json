{
  "name": "simulador",
  "private": true,
  "version": "0.2.0",
  "description": "Flow Simulation Editor - discrete event simulation with graph-based models",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace @simulador/ui",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "npm run dev --workspace @simulador/app",
    "start": "npm run start --workspace @simulador/app",
    "package": "npm run build && npm run package --workspace @simulador/app",
    "release": "npm run build && npm run release --workspace @simulador/app",
    "version-bump": "node scripts/version-bump.mjs",
    "icons:build": "node scripts/build-icons.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "png2icons": "^2.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
